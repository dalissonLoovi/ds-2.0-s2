{
  "name": "@ds/storybook",
  "version": "0.1.0",
  "private": true,
  "description": "Design System 2.0 — Storybook docs catalog (seed from Figma metadata JSON)",
  "type": "module",
  "scripts": {
    "docs:generate": "node ./scripts/generate-docs-from-json.mjs",
    "prestorybook": "npm run docs:generate",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run docs:generate",
    "build-storybook": "storybook build -o storybook-static",
    "build-storybook:pages": "cross-env GITHUB_PAGES=true npm run build-storybook"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.14",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
